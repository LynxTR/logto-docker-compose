# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_DB=logto
POSTGRES_USER=logto
POSTGRES_PASSWORD=change_me_strong_password

# ----------------------------------------------------------
# Logto
# ----------------------------------------------------------
ENDPOINT=https://auth.example.com
ADMIN_ENDPOINT=https://admin.example.com
TRUST_PROXY_HEADER=1
LOGTO_PORT=3001
LOGTO_ADMIN_PORT=3002

# ----------------------------------------------------------
# Custom CA certificate (optional)
# Set CA_CERT_HOST_PATH to the certificate file on the host and
# NODE_EXTRA_CA_CERTS to the path it should be mounted at inside
# the container.  Both must be set together.
# Example:
#   CA_CERT_HOST_PATH=./my-ca.pem
#   NODE_EXTRA_CA_CERTS=/etc/ssl/certs/my-ca.pem
# ----------------------------------------------------------
# CA_CERT_HOST_PATH=
# NODE_EXTRA_CA_CERTS=

# ----------------------------------------------------------
# Image tags
# ----------------------------------------------------------
LOGTO_TAG=latest
POSTGRES_TAG=17-alpine
